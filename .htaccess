Options -Indexes

# ─── HTTPS forzado en producción ───────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTP_HOST} canettocookies.com [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Redirigir raíz del subdominio admin al panel ──────────────────────────
RewriteCond %{HTTP_HOST} ^administracion\.canettocookies\.com$ [NC]
RewriteRule ^$ /administracion/index.php [L,R=302]

# ─── Proteger archivos sensibles ───────────────────────────────────────────
<FilesMatch "\.(env|log|sql|sh|bak|git|json|lock|md)$">
    Require all denied
</FilesMatch>

# ─── Bloquear acceso directo a carpetas críticas ───────────────────────────
RedirectMatch 403 ^/config/
RedirectMatch 403 ^/vendor/

# ─── Headers de seguridad ──────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ─── Comprimir respuestas ──────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ─── Cache de assets estáticos ────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
